# Cobalt Boat runtime environment
# Installed to /etc/default/cobalt-boat

# API is local-only by default; use reverse proxy/tunnel intentionally if needed.
COBALT_API_HOST=127.0.0.1
COBALT_API_PORT=8080

# SocketCAN
COBALT_CAN_INTERFACE=can0
COBALT_CAN_BITRATE=250000
COBALT_AUTO_CONFIGURE_CAN_INTERFACE=false

# Authoritative decoder configuration
COBALT_DECODER_BACKEND=canboat
COBALT_CANBOAT_COMMAND=/usr/local/bin/cobalt-canboat-decoder
COBALT_DECODER_REQUIRED=true
COBALT_ALLOW_BASIC_DECODER_INSECURE=false
COBALT_CANBOAT_RESPONSE_TIMEOUT_SEC=1.0
COBALT_CANBOAT_EXPECTED_VERSION=v6.1.6

# Data and safety defaults
COBALT_DATA_DIR=__COBALT_REPO_ROOT__/data
COBALT_CAPTURE_DIR=__COBALT_REPO_ROOT__/data/captures
COBALT_SQLITE_PATH=__COBALT_REPO_ROOT__/data/cobalt_boat.db
COBALT_READ_ONLY_MODE=true
COBALT_WRITE_ENABLE=false
COBALT_EMERGENCY_DISABLE=false

# Logging (verbosity)
COBALT_LOG_LEVEL=INFO
COBALT_APP_LOG_PATH=/var/log/cobalt-boat/cobalt-boat.log
# Cap text log size on SD card (bytes per file; kept backups = COBALT_LOG_BACKUP_COUNT).
# Set COBALT_LOG_MAX_BYTES=0 for one unbounded file (use logrotate only).
COBALT_LOG_MAX_BYTES=5242880
COBALT_LOG_BACKUP_COUNT=7
